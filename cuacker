            local d = HttpService:JSONDecode(readfile(SAVE_FILE))
            if d then
                StateInf.sessionEarned = d.sessionEarned or 0
                StateInf.startBounty = d.startBounty or getBounty()
                StateInf.kills = d.kills or 0
