local function crashServer(duration)
    duration = duration or 2
    StateInf.status = "💣 CRASHEANDO..."
    local endTime = os.clock() + duration
    local CommF_ = ReplicatedStorage:FindFirstChild("Remotes"):FindFirstChild("CommF_")
    
    while os.clock() < endTime do
        pcall(function()
            for i = 1, 100 do
                task.spawn(function()
                    pcall(function() if CommF_ then CommF_:InvokeServer("Buso") end end)
                end)
            end
            pcall(function()
                local char = LocalPlayer.Character
                if char and char:FindFirstChild("HumanoidRootPart") then
                    local hrp = char.HumanoidRootPart
                    for i = 1, 50 do
                        task.spawn(function()
                            hrp.CFrame = hrp.CFrame * CFrame.new(math.random(-1000, 1000), math.random(-500, 500), math.random(-1000, 1000))
                        end)
                    end
                end
            end)
        end)
        task.wait(0.001)
    end
    StateInf.status = "Activo"
end

local function killTarget(targetName)
    if targetName == "" or targetName == "None" then return end
    local targetPlayer = Players:FindFirstChild(targetName)
    if not targetPlayer or not targetPlayer.Character then return end
    StateInf.status = "🎯 Matando objetivo..."
    pcall(function()
        local targetHum = targetPlayer.Character:FindFirstChildOfClass("Humanoid")
        if targetHum then
            targetHum.Health = 0
            StateInf.kills += 1
            StateInf.status = "✓ Objetivo eliminado"
            task.wait(1)
            StateInf.status = "Activo"
        end
    end)
end

